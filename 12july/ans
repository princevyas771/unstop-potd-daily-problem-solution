import java.util.*;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        HashMap<Integer, Integer> freq = new HashMap<>();

        for (int i = 0; i < n; i++) {
            int id = sc.nextInt();
            freq.put(id, freq.getOrDefault(id, 0) + 1);
        }

        int maxFreq = 0;
        int answerId = Integer.MAX_VALUE;

        for (Map.Entry<Integer, Integer> entry : freq.entrySet()) {
            int id = entry.getKey();
            int count = entry.getValue();

            if (count > maxFreq) {
                maxFreq = count;
                answerId = id;
            } else if (count == maxFreq && id < answerId) {
                answerId = id;
            }
        }

        System.out.println(answerId + " " + maxFreq);
    }
}
