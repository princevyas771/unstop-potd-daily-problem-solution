
    // Create a copy to sort, since the original is passed as a const reference
    std::vector<long> sorted_distances = distances;
    std::sort(sorted_distances.begin(), sorted_distances.end());
    
    int count = 1;
    long last_selected_position = sorted_distances[0];
    
    for (int i = 1; i < n; ++i) {
        if (sorted_distances[i] - last_selected_position >= d) {
            count++;
            last_selected_position = sorted_distances[i];
        }
    }
    
    return count;
}

